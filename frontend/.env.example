# =============================================================================
# MMOS Frontend (Vercel) — Environment-Variablen
# =============================================================================
# In Vercel → Project Settings → Environment Variables eintragen.
# NEXT_PUBLIC_* sind im Browser sichtbar — KEINE Secrets dort ablegen.

# --- Supabase (Browser-Auth) ----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=           # [PFLICHT] https://<projekt>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # [PFLICHT] Anon-Key (NICHT der Service-Role-Key!)

# --- Backend-Anbindung (Railway) ------------------------------------------
# Der Browser ruft same-origin /api/* auf; die Next-Proxy-Route leitet an das
# Backend weiter. Setze EINE dieser server-seitigen Variablen auf die Railway-URL:
BACKEND_URL=                        # [PFLICHT] https://<dein-backend>.up.railway.app
RAILWAY_BACKEND_URL=                # (Alias/Fallback fuer BACKEND_URL)
NEXT_PUBLIC_BACKEND_URL=            # (nur falls Direktaufrufe ohne Proxy gewuenscht)

# Direkter Backend-Modus (statt Proxy) — optional:
# NEXT_PUBLIC_ENABLE_DIRECT_BACKEND=false
# NEXT_PUBLIC_API_BASE=             # https://<dein-backend> (nur bei Direktmodus)

# --- App-URL ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=                # [EMPF] eigene Frontend-Domain (Canonical/Links)

# --- Feature-Flags ---------------------------------------------------------
NEXT_PUBLIC_ENABLE_DEMO_MODE=false  # Demo-Modus im UI
NEXT_PUBLIC_ENABLE_LOCAL_WRITE_FALLBACK=false # Nur fuer lokale Entwicklung/Demo; Live niemals auf true setzen
NEXT_PUBLIC_REQUIRE_ROUTE_GUARD=true # Middleware: /admin etc. nur mit Session (Login-Redirect)

# --- Build (von Vercel automatisch) ---------------------------------------
# NODE_ENV wird von Vercel gesetzt — nicht manuell eintragen.
