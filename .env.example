# --- Supabase (EU / Frankfurt) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Drizzle migrations + seed) ---
# Use the Supabase "Connection string" (Direct connection, port 5432) for migrations.
DATABASE_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- Stripe (Tool 3: Billing) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Recurring Price IDs per tool (Stripe Dashboard → Products).
STRIPE_PRICE_LOYALTY=price_xxx
STRIPE_PRICE_REVIEWS=price_xxx
STRIPE_PRICE_PAYMENTS=price_xxx
STRIPE_PRICE_BOOKING=price_xxx
STRIPE_PRICE_NEWSLETTER=price_xxx
STRIPE_PRICE_REFERRAL=price_xxx
STRIPE_PRICE_SEO=price_xxx

# --- Email (Tool 4: Booking confirmations) ---
# Optional — without it, booking confirmation emails are skipped gracefully.
RESEND_API_KEY=
MAIL_FROM=MMOS <noreply@example.com>

# --- DSGVO ---
# Salt for one-way IP hashing in the consent ledger.
CONSENT_IP_SALT=change-me

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
