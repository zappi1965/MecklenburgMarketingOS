# =============================================================================
# MMOS Backend (Railway) — Environment-Variablen
# =============================================================================
# Kopiere relevante Zeilen in Railway → Variables. Werte NICHT committen.
# Legende:  [PFLICHT] = ohne startet/funktioniert es nicht
#           [EMPF]    = stark empfohlen fuer Live-Betrieb
#           [FEATURE] = nur noetig, wenn das Feature genutzt wird
#           Defaults in Klammern.

# --- Kern / Supabase -------------------------------------------------------
SUPABASE_URL=                       # [PFLICHT] https://<projekt>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # [PFLICHT] Service-Role-Key (geheim!)
NODE_ENV=production                  # [PFLICHT] production
PORT=4000                           # (Railway setzt PORT meist selbst)

# --- Oeffentliche URLs / Links (Mails, QR, Wallet, Buchung) ----------------
PUBLIC_APP_URL=                     # [EMPF] Frontend-Domain, z.B. https://app.deine-domain.de
APP_PUBLIC_URL=                     # [FEATURE] Stripe-Checkout-Redirects (gleicher Wert wie PUBLIC_APP_URL)
FRONTEND_URL=                       # (Fallback fuer Portal-Links; sonst PUBLIC_APP_URL)

# --- E-Mail-Versand (Resend) ----------------------------------------------
RESEND_API_KEY=                     # [EMPF] Resend-API-Key (sonst Mail-Dry-Run im Log)
MAIL_FROM=Mecklenburg Marketing <noreply@mecklenburgmarketing.de> # [EMPF] in Resend verifizierte Absender-Domain
PACKAGE_INQUIRY_TO=zapf@mecklenburgmarketing.de # [FEATURE] Empfänger für öffentliche Paket-/Setup-Anfragen
PACKAGE_INQUIRY_FROM=Mecklenburg Marketing <noreply@mecklenburgmarketing.de> # [FEATURE] Absender für öffentliche Paket-/Setup-Anfragen

# --- Admin-Bootstrap (erster Admin) ---------------------------------------
ADMIN_PROFILE_SETUP_TOKEN=          # [EMPF] Token fuer Erst-Anlage des Admin-Profils
# ALLOW_ADMIN_BOOTSTRAP=true        # Alternative: erlaubt einmalige Admin-Anlage ohne Token

# --- Wallet-Self-Service (/wallet/me Magic-Links) -------------------------
WALLET_TOKEN_SECRET=                # [PFLICHT in Prod, wenn /wallet/me genutzt] langer Zufallsstring
WALLET_REQUEST_LIMIT_PER_HOUR=5     # (5)

# --- KI (AI Review-Antwort, AI Social-Posts, Chatbot) ----------------------
AI_PROVIDER=anthropic               # [FEATURE] anthropic | openai | mock  (ohne Key -> mock)
ANTHROPIC_API_KEY=                  # [FEATURE] fuer AI_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-5   # (Default)
OPENAI_API_KEY=                     # [FEATURE] fuer AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini            # (Default)

# --- E-Rechnung (XRechnung / ZUGFeRD) — Verkaeufer-Stammdaten ---------------
E_INVOICE_SELLER_NAME=              # [FEATURE] Firmenname
E_INVOICE_SELLER_ADDRESS=          # Strasse + Nr.
E_INVOICE_SELLER_POSTAL_CODE=
E_INVOICE_SELLER_CITY=
E_INVOICE_SELLER_COUNTRY=DE         # (DE)
E_INVOICE_SELLER_VAT_ID=            # USt-IdNr.
E_INVOICE_SELLER_TAX_ID=            # Steuernummer
E_INVOICE_SELLER_EMAIL=
E_INVOICE_SELLER_IBAN=
E_INVOICE_SELLER_BIC=

# --- Zahlungen -------------------------------------------------------------
STRIPE_SECRET_KEY=                  # [FEATURE] Stripe
STRIPE_WEBHOOK_SECRET=              # [FEATURE] Stripe-Webhook-Signatur
PAYPAL_CLIENT_ID=                   # [FEATURE] PayPal
PAYPAL_CLIENT_SECRET=

# --- Google (GMB / SEO / OAuth / Places) -----------------------------------
GOOGLE_PLACES_API_KEY=              # [FEATURE] Places (Bewertungen/Standort)
GOOGLE_PLACES_CACHE_TTL_MS=86400000 # (24h)
GOOGLE_PLACES_MAX_SEARCHES_PER_HOUR=100
GOOGLE_CLIENT_ID=                   # [FEATURE] OAuth (GMB/Search Console)
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=                # https://<backend>/api/google/callback
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_ANALYTICS_PROPERTY_ID=
GMB_PROVIDER=mock                   # [FEATURE] mock | google

# --- PDF (Gotenberg) -------------------------------------------------------
GOTENBERG_URL=                      # [FEATURE] PDF-Render-Service. Leer lassen, wenn nicht aktiv; niemals null/undefined eintragen.
GOTENBERG_TIMEOUT_MS=30000          # (30s)

# --- Wallet-Paesse (Apple / Google) ----------------------------------------
APPLE_WALLET_CERT_PEM=              # [FEATURE] Apple Wallet
APPLE_WALLET_KEY_PEM=
APPLE_WALLET_KEY_PASSPHRASE=
APPLE_WALLET_WWDR_PEM=
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
GOOGLE_WALLET_ISSUER_ID=           # [FEATURE] Google Wallet
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
GOOGLE_WALLET_CLASS_SUFFIX=
GOOGLE_WALLET_ORIGINS=

# --- TSE / KassenSichV -----------------------------------------------------
TSE_PROVIDER=mock                   # [FEATURE] mock | fiskaly
TSE_API_KEY=
TSE_DEVICE_ID=

# --- Adress-/Geo-Validierung -----------------------------------------------
GEOCODER_PROVIDER=nominatim         # [FEATURE] nominatim | google
NOMINATIM_USER_AGENT=mmos/1.0 (kontakt@deine-domain.de)
GOOGLE_GEOCODING_KEY=               # nur fuer GEOCODER_PROVIDER=google

# --- Monitoring (Sentry) ---------------------------------------------------
SENTRY_DSN=                         # [EMPF] Fehler-Monitoring (PII-sicher gescrubt)
SENTRY_TRACES_SAMPLE_RATE=0.1       # (0.1)

# --- Sicherheit / Rate-Limits / Proxy --------------------------------------
MFA_ISSUER_NAME=MMOS                # (MMOS) Anzeigename in Authenticator-Apps
TRUST_PROXY_HOPS=1                  # (1) hinter Railway-Proxy; RAILWAY_TRUST_PROXY_HOPS als Alias
RATE_LIMIT_MAX=                     # globales Limit (Default im Code)
AUTH_RATE_LIMIT_MAX=                # Login-Limit
BOOKING_RATE_LIMIT_PER_MIN=10       # (10)
QR_RATE_LIMIT_PER_MIN=60            # (60)
CHATBOT_RATE_LIMIT_PER_MIN=         # (Default im Code)

# --- Cron-Ausdruecke der Worker (nur bei eigenem Worker-Service) -----------
AUTOMATION_WORKER_CRON=*/15 * * * *  # (alle 15 Min) Termin->Rechnung, Review->Ticket, QR->Lead, Monatsreport
GDPR_WORKER_CRON=30 4 * * *          # (04:30) DSGVO-Loeschanfragen abarbeiten
DAILY_BRIEFING_CRON=0 7 * * *        # (07:00) taegliche Briefing-Mail
MAINTENANCE_CHECK_CRON=30 5 * * *    # (05:30 UTC) Wartungs-/Onboarding-Scan
